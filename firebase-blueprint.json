{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user in the system.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "teacher"] },
        "createdAt": { "type": "number", "description": "Timestamp ms" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Classroom": {
      "title": "Classroom",
      "description": "A classroom managed by a teacher.",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["teacherId", "name", "createdAt"]
    },
    "PCA": {
      "title": "Personal Care Assistant",
      "description": "A PCA assigned to a classroom. They do not log in directly, they use the teacher's device.",
      "type": "object",
      "properties": {
        "classroomId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["classroomId", "name", "createdAt"]
    },
    "Student": {
      "title": "Student",
      "description": "A student in a classroom.",
      "type": "object",
      "properties": {
        "classroomId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["classroomId", "name", "createdAt"]
    },
    "ServiceLog": {
      "title": "Service Log",
      "description": "A log of a Medicaid service provided to a student.",
      "type": "object",
      "properties": {
        "classroomId": { "type": "string" },
        "studentId": { "type": "string" },
        "pcaId": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["Dressing", "Eating/Meal Prep", "Mobility/Ambulation", "Positioning/Transferring", "Toileting/Diapering"] },
        "startTime": { "type": "number" },
        "endTime": { "type": "number" },
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["classroomId", "studentId", "pcaId", "serviceType", "startTime", "date", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users (admins and teachers)"
    },
    "classrooms/{classroomId}": {
      "schema": { "$ref": "#/entities/Classroom" },
      "description": "Classrooms"
    },
    "pcas/{pcaId}": {
      "schema": { "$ref": "#/entities/PCA" },
      "description": "Personal Care Assistants"
    },
    "students/{studentId}": {
      "schema": { "$ref": "#/entities/Student" },
      "description": "Students"
    },
    "serviceLogs/{serviceLogId}": {
      "schema": { "$ref": "#/entities/ServiceLog" },
      "description": "Service Logs"
    }
  }
}
